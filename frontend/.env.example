# Доступен и в браузере, и на сервере (Next.js встраивает значения с префиксом NEXT_PUBLIC_ в бандл при сборке)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Доступен только на сервере (Server Components, route handlers). В Docker — служебное имя контейнера бекенда.
# 127.0.0.1 вместо localhost: Node.js резолвит "localhost" в IPv6 (::1) первым,
# а uvicorn по умолчанию слушает только IPv4 — отсюда ECONNREFUSED при fetch с сервера.
INTERNAL_API_URL=http://127.0.0.1:8000
